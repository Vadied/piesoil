# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string.
#
# Local dev — direct TCP connection to a local Postgres instance:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/app
#
# Cloud Run — the Cloud SQL Auth Proxy sidecar listens on a Unix socket.
# Include connection pool parameters to limit the connections per Cloud Run
# instance (each instance has its own Prisma query engine pool):
#   DATABASE_URL=postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE&connection_limit=5&pool_timeout=2
#
DATABASE_URL=postgresql://postgres:password@localhost:5432/app

# =============================================================================
# NEXTAUTH.JS
# =============================================================================

# Secret used to sign and encrypt JWTs and session cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of this deployment — used for OAuth redirect URIs and email links.
# Local dev: http://localhost:3000
# Production: the public Cloud Run URL or custom domain (e.g. https://app.example.com)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH (provider for NextAuth.js)
# =============================================================================

# OAuth 2.0 client credentials from Google Cloud Console.
# Authorised redirect URI must include: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# GOOGLE CLOUD STORAGE
# =============================================================================

# Name of the GCS bucket used to store uploaded cover images.
# The bucket must be publicly readable (uniform access, allUsers: objectViewer).
GCS_BUCKET_NAME=

# =============================================================================
# GOOGLE ANALYTICS 4
# =============================================================================

# GA4 Measurement ID (format: G-XXXXXXXXXX).
# Exposed to the browser via Next.js NEXT_PUBLIC_ convention.
# Loaded only after explicit user consent (Consent Mode v2).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# =============================================================================
# DATABASE SEED
# =============================================================================

# Credentials for the initial admin user created by `npm run db:seed`.
# Required only when running the seed — not needed at runtime.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# Optional display name for the admin user (defaults to "Admin").
SEED_ADMIN_NAME=Admin

# =============================================================================
# APPLICATION
# =============================================================================

# Node.js environment. Set to "production" in Cloud Run.
NODE_ENV=development
